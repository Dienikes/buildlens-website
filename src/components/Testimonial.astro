---
/**
 * Testimonial — Centered blockquote with line reveals.
 * Placeholder content (fictional, pre-launch).
 */
---

<section class="py-32 lg:py-48 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <p class="text-6xl lg:text-8xl leading-none select-none" style="color: var(--accent-dim);">
      &ldquo;
    </p>

    <blockquote data-reveal="lines" class="mt-4">
      <p class="text-2xl lg:text-4xl font-medium leading-relaxed" style="color: var(--text-lit);">
        BuildLens replaced our entire patchwork of spreadsheets and shared drives.
        For the first time, every stakeholder sees the same data.
      </p>
    </blockquote>

    <div data-reveal="fade" class="mt-10">
      <p class="font-mono text-sm" style="color: var(--accent);">
        Sarah Mitchell
      </p>
      <p class="font-mono text-xs mt-1" style="color: var(--text-shadow);">
        Operations Manager, Meridian Construction
      </p>
    </div>
  </div>
</section>
