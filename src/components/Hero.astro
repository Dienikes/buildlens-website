---
/**
 * Hero — Above-the-fold intro section.
 * Heading bleeds off left edge on desktop per spec wireframe.
 * data-reveal="lines" on heading, data-reveal="fade" on subtext.
 */
---

<section class="hero-section min-h-screen flex flex-col justify-center relative">
  <div class="hero-content">
    <h1 class="hero-heading hero-reveal">
      Construction<br />
      logistics. One<br />
      <span style="color: var(--accent);">source of truth.</span>
    </h1>

    <div class="hero-right">
      <p
        class="hero-reveal text-lg lg:text-xl"
        style="color: var(--text-mid);"
      >
        BuildLens consolidates purchase orders, submittals, scheduling, and field
        coordination into a single operational hub — powered by an AI co-pilot that
        reads your project data without it ever leaving the network.
        Built by operators, for operators.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <a
          href="/contact"
          data-magnetic
          data-cursor="action"
          class="inline-flex items-center justify-center px-8 py-4 border rounded-full font-mono text-sm transition-colors min-w-[180px] min-h-[44px]"
          style="color: var(--accent); border-color: var(--accent-border);"
        >
          Request a Demo
        </a>
        <a
          href="#value"
          data-cursor="pointer"
          class="font-mono text-sm transition-colors"
          style="color: var(--text-mid);"
        >
          Learn more &darr;
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
    <p class="font-mono text-xs uppercase tracking-[0.2em]" style="color: var(--accent-dim);">
      Scroll
    </p>
    <div class="w-px h-8 animate-pulse-down" style="background: var(--accent-dim);"></div>
  </div>
</section>

<style>
  .hero-section {
    padding: 0 1.5rem;
  }

  .hero-content {
    max-width: 90rem;
    margin: 0 auto;
    width: 100%;
  }

  .hero-heading {
    line-height: 0.95;
  }

  /* Hero content is visible by default — no JS-driven reveal to avoid
     double-animation with the splash screen dissolve */
  .hero-reveal {
    opacity: 1;
  }

  .hero-right {
    margin-top: 2.5rem;
    max-width: 32rem;
  }

  @media (min-width: 1024px) {
    .hero-section {
      padding: 0 3rem;
    }

    .hero-heading {
      margin-left: -1rem;
    }

    .hero-right {
      margin-left: auto;
      margin-top: 3rem;
    }
  }

  @media (min-width: 1280px) {
    .hero-heading {
      margin-left: -1.5rem;
    }
  }
</style>
