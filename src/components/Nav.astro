---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/platform', label: 'Platform' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 w-full z-100 transition-colors duration-300"
  aria-label="Main navigation"
>
  <div class="mx-auto flex items-center justify-between px-6 lg:px-12" style="height: 80px;">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-xl font-bold" data-cursor="pointer" style="color: var(--text-lit);">
      <span style="color: var(--accent);">BL</span>
    </a>

    <!-- Desktop Nav Links -->
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          data-magnetic
          data-cursor="pointer"
          class:list={[
            'font-mono text-sm tracking-wide py-2 px-3 min-h-[44px] min-w-[44px] inline-flex items-center transition-colors',
            currentPath.startsWith(link.href) ? 'nav-link-active' : 'nav-link',
          ]}
        >
          {link.label}
        </a>
      ))}

      <!-- CTA Button -->
      <a
        href="/contact"
        data-magnetic
        data-cursor="action"
        class="ml-4 inline-flex items-center justify-center px-6 py-3 rounded-full font-mono text-sm min-h-[44px] transition-colors nav-cta"
      >
        Request Demo
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="nav-hamburger"
      class="md:hidden flex flex-col justify-center items-center w-11 h-11 gap-1.5"
      aria-label="Open menu"
      aria-expanded="false"
      data-cursor="pointer"
    >
      <span class="hamburger-line w-6 h-px transition-transform duration-300" style="background: var(--text-lit);"></span>
      <span class="hamburger-line w-6 h-px transition-transform duration-300" style="background: var(--text-lit);"></span>
      <span class="hamburger-line w-4 h-px transition-transform duration-300 self-end" style="background: var(--text-lit);"></span>
    </button>
  </div>
</nav>

<!-- Mobile Overlay -->
<div
  id="nav-overlay"
  class="fixed inset-0 z-[101] flex flex-col pointer-events-none opacity-0"
  style="background: var(--bg-deep);"
  aria-hidden="true"
>
  <div class="flex items-center justify-between px-6" style="height: 64px;">
    <a href="/" class="text-xl font-bold" style="color: var(--text-lit);">
      <span style="color: var(--accent);">BL</span>
    </a>
    <button
      id="nav-close"
      class="flex items-center justify-center w-11 h-11"
      aria-label="Close menu"
      data-cursor="pointer"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--text-lit);">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </button>
  </div>

  <div class="flex-1 flex flex-col justify-center px-6 gap-6">
    {links.map((link) => (
      <a
        href={link.href}
        class="overlay-link font-bold transition-colors"
        style={`font-size: clamp(2rem, 6vw, 4rem); color: var(--text-lit);`}
        data-cursor="pointer"
      >
        {link.label}
      </a>
    ))}

    <a
      href="/contact"
      data-magnetic
      data-cursor="action"
      class="mt-8 inline-flex items-center justify-center self-start px-8 py-4 rounded-full font-mono text-sm min-h-[44px] nav-cta"
    >
      Request Demo
    </a>
  </div>

  <div class="px-6 pb-8 flex flex-col gap-1">
    <p class="font-mono text-sm" style="color: var(--text-shadow);">info@buildlens.com</p>
    <p class="font-mono text-sm" style="color: var(--text-shadow);">Madison, AL</p>
  </div>
</div>

<style>
  .nav-link {
    color: var(--text-mid);
  }
  .nav-link:hover {
    color: var(--text-lit);
  }
  .nav-link-active {
    color: var(--accent);
  }
  .nav-cta {
    color: var(--accent);
    border: 1px solid var(--accent-border);
  }
  .nav-cta:hover {
    background: var(--accent-bg);
    color: var(--text-lit);
  }
  #main-nav.scrolled {
    background: rgba(22, 27, 34, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: var(--shadow-md);
  }
</style>
