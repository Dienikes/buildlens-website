---
/**
 * PlatformPreview — Product screenshots in browser-chrome frames.
 */
import { Image } from 'astro:assets';
import ganttImg from '../assets/images/screenshot-gantt.png';
import dashboardImg from '../assets/images/screenshot-dashboard.png';
import pipelineImg from '../assets/images/screenshot-pipeline.png';
import rfiImg from '../assets/images/screenshot-rfi.png';

const thumbnails = [
  { src: dashboardImg, alt: 'BuildLens project dashboard', title: 'Project Dashboard', desc: 'Budget, schedule, and team activity at a glance.' },
  { src: pipelineImg, alt: 'BuildLens pursuit pipeline board', title: 'Pursuit Pipeline', desc: 'Track opportunities from identification through proposal.' },
  { src: rfiImg, alt: 'BuildLens RFI and submittal tracker', title: 'RFI Tracker', desc: 'Manage requests for information with full audit trails.' },
];
---

<section class="py-32 lg:py-48 px-6 lg:px-12">
  <div class="max-w-6xl mx-auto">
    <p
      class="font-mono text-xs uppercase tracking-[0.2em] mb-6 text-center"
      style="color: var(--accent);"
    >
      The Platform
    </p>

    <h2 class="text-center mb-16 lg:mb-24" data-reveal="lines">
      See it in action.
    </h2>

    <!-- Hero screenshot: Gantt view -->
    <div data-reveal="fade">
      <div class="browser-frame">
        <div class="browser-bar">
          <span class="browser-dot"></span>
          <span class="browser-dot"></span>
          <span class="browser-dot"></span>
          <div class="browser-url">
            <span class="font-mono text-xs" style="color: var(--text-shadow);">app.buildlens.com/schedule</span>
          </div>
        </div>
        <div class="overflow-hidden">
          <Image
            src={ganttImg}
            alt="BuildLens schedule and Gantt chart view"
            width={1360}
            height={793}
            loading="lazy"
            class="w-full h-auto block"
            data-parallax="0.1"
          />
        </div>
      </div>

      <div class="mt-6 text-center">
        <h3 class="text-xl lg:text-2xl" style="color: var(--text-lit);">
          Master Your Schedule
        </h3>
        <p class="mt-2 text-sm" style="color: var(--text-mid);">
          Gantt charts that sync directly with procurement. Every delay is visible before it cascades.
        </p>
      </div>
    </div>

    <!-- Thumbnail grid -->
    <div class="grid md:grid-cols-3 gap-6 mt-16 lg:mt-24" data-reveal="stagger">
      {thumbnails.map((thumb) => (
        <div>
          <div class="browser-frame browser-frame-sm">
            <div class="browser-bar browser-bar-sm">
              <span class="browser-dot browser-dot-sm"></span>
              <span class="browser-dot browser-dot-sm"></span>
              <span class="browser-dot browser-dot-sm"></span>
            </div>
            <div class="overflow-hidden">
              <Image
                src={thumb.src}
                alt={thumb.alt}
                width={1360}
                height={793}
                loading="lazy"
                class="w-full h-auto block"
              />
            </div>
          </div>
          <div class="mt-4">
            <h4 class="text-sm font-mono" style="color: var(--text-lit);">{thumb.title}</h4>
            <p class="mt-1 text-xs" style="color: var(--text-mid);">{thumb.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .browser-frame {
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--border-mid);
    box-shadow: var(--shadow-xl);
    background: var(--bg-raised);
  }

  .browser-frame-sm {
    box-shadow: var(--shadow-md);
  }

  .browser-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--glass-06);
    border-bottom: 1px solid var(--border-subtle);
  }

  .browser-bar-sm {
    padding: 0.5rem 0.75rem;
    gap: 0.375rem;
  }

  .browser-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--glass-10);
  }

  .browser-dot-sm {
    width: 7px;
    height: 7px;
  }

  .browser-url {
    margin-left: 0.75rem;
    padding: 0.25rem 0.75rem;
    border-radius: 0.375rem;
    background: var(--glass-03);
  }
</style>
