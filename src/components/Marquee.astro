---
/**
 * Marquee — Dual-direction infinite scroll keyword strip.
 * Uses the existing data-marquee system from marquee.ts.
 */
const row1 = [
  'Purchase Orders',
  'Submittals',
  'Scheduling',
  'BOMs',
  'RFI Tracking',
  'Field Coordination',
  'Budget Tracking',
  'Document Control',
  'Equipment Sourcing',
  'Workflow Automation',
  'Subcontractor Mgmt',
  'Reporting',
];

const row2 = [
  'Gantt Charts',
  'Procurement Pipeline',
  'Submittal Routing',
  'Cost Forecasting',
  'Change Orders',
  'Inspection Logs',
  'Material Tracking',
  'Bid Management',
  'Daily Reports',
  'Safety Compliance',
  'Punch Lists',
  'Closeout Docs',
];
---

<section class="py-16 lg:py-24 overflow-hidden">
  <div data-marquee data-marquee-speed="30">
    <div class="marquee-track">
      {row1.map((word) => (
        <span class="marquee-word">{word}</span>
      ))}
    </div>
  </div>

  <div class="mt-3 lg:mt-4" data-marquee data-marquee-direction="reverse" data-marquee-speed="35">
    <div class="marquee-track">
      {row2.map((word) => (
        <span class="marquee-word">{word}</span>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-track {
    display: inline-flex;
    align-items: center;
    gap: 2rem;
    padding: 0 1rem;
  }

  @media (min-width: 1024px) {
    .marquee-track {
      gap: 3rem;
      padding: 0 1.5rem;
    }
  }

  .marquee-word {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    white-space: nowrap;
    color: var(--text-shadow);
    transition: color 0.3s ease;
  }

  @media (min-width: 1024px) {
    .marquee-word {
      font-size: 0.875rem;
    }
  }

  .marquee-word:hover {
    color: var(--accent);
  }
</style>
