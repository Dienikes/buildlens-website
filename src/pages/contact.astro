---
/**
 * Contact Page — Demo request form + contact info sidebar.
 * Phase 6c: "Let's Talk" heading, form, magnetic submit, contact details.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | BuildLens — Construction Logistics Platform"
  description="Request a demo or get in touch with the BuildLens team. We're based in Madison, AL."
>
  <!-- Hero -->
  <section class="pt-40 pb-16 lg:pt-48 lg:pb-20 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <p
        class="font-mono text-xs uppercase tracking-[0.2em] mb-6"
        style="color: var(--accent);"
        data-reveal="fade"
      >
        Get in Touch
      </p>
      <h1 class="contact-heading" data-reveal="lines">
        Let's Talk.
      </h1>
      <div class="contact-rule mt-8" data-reveal="fade"></div>
    </div>
  </section>

  <!-- Form + Sidebar -->
  <section class="pb-32 lg:pb-48 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="contact-grid">
        <!-- Form -->
        <div class="contact-form-wrap" data-reveal="fade">
          <form id="contact-form" class="contact-form" novalidate>
            <div class="form-row">
              <div class="form-group">
                <label for="name" class="form-label">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  class="form-input"
                  placeholder="Your full name"
                />
              </div>
              <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  class="form-input"
                  placeholder="you@company.com"
                />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="company" class="form-label">Company</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  autocomplete="organization"
                  class="form-input"
                  placeholder="Your company name"
                />
              </div>
              <div class="form-group">
                <label for="role" class="form-label">Role</label>
                <input
                  type="text"
                  id="role"
                  name="role"
                  class="form-input"
                  placeholder="e.g. Project Manager"
                />
              </div>
            </div>

            <div class="form-group">
              <label for="message" class="form-label">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                class="form-input form-textarea"
                placeholder="Tell us about your projects and what you're looking for..."
              ></textarea>
            </div>

            <div class="mt-8">
              <button
                type="submit"
                data-magnetic
                data-cursor="action"
                class="submit-btn inline-flex items-center justify-center px-10 py-5 border rounded-full font-mono text-sm transition-colors min-w-[200px] min-h-[48px]"
              >
                Request a Demo
              </button>
            </div>
          </form>
        </div>

        <!-- Sidebar -->
        <aside class="contact-sidebar" data-reveal="fade">
          <div class="sidebar-card">
            <p class="font-mono text-xs uppercase tracking-[0.2em] mb-6" style="color: var(--accent);">
              Contact Info
            </p>

            <ul class="sidebar-list">
              <li>
                <p class="sidebar-label">Email</p>
                <a
                  href="mailto:info@buildlens.com"
                  class="sidebar-value sidebar-link"
                  data-cursor="pointer"
                >
                  info@buildlens.com
                </a>
              </li>
              <li>
                <p class="sidebar-label">Phone</p>
                <a
                  href="tel:+12565551234"
                  class="sidebar-value sidebar-link"
                  data-cursor="pointer"
                >
                  (256) 555-1234
                </a>
              </li>
              <li>
                <p class="sidebar-label">Location</p>
                <p class="sidebar-value">Madison, AL</p>
              </li>
            </ul>
          </div>

          <div class="sidebar-card mt-6">
            <p class="font-mono text-xs uppercase tracking-[0.2em] mb-4" style="color: var(--accent);">
              Response Time
            </p>
            <p class="text-sm" style="color: var(--text-mid);">
              We typically respond within one business day. For urgent inquiries, give us a call.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Heading */
  .contact-heading {
    font-size: clamp(2.5rem, 7vw, 7rem);
    line-height: 0.95;
  }

  .contact-rule {
    width: 80px;
    height: 2px;
    background: var(--accent);
  }

  /* Grid: form + sidebar */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .contact-grid {
      grid-template-columns: 3fr 1fr;
      gap: 4rem;
    }
  }

  /* Form */
  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 640px) {
    .form-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-mid);
  }

  .form-input {
    background: var(--glass-03);
    border: 1px solid var(--border-subtle);
    border-radius: 0.5rem;
    padding: 0.875rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--text-lit);
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
  }

  .form-input::placeholder {
    color: var(--text-shadow);
  }

  .form-input:focus {
    outline: none;
    border-color: var(--accent-border);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* Submit button */
  .submit-btn {
    color: var(--accent);
    border-color: var(--accent-border);
    background: transparent;
    cursor: none;
  }

  .submit-btn:hover {
    background: var(--glass-06);
  }

  @media (max-width: 639px) {
    .submit-btn {
      width: 100%;
    }
  }

  /* Sidebar */
  .sidebar-card {
    background: var(--glass-03);
    border: 1px solid var(--border-subtle);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .sidebar-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .sidebar-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-shadow);
    margin-bottom: 0.25rem;
  }

  .sidebar-value {
    font-size: 0.9375rem;
    color: var(--text-mid);
  }

  .sidebar-link {
    text-decoration: none;
    transition: color 0.2s;
  }

  .sidebar-link:hover {
    color: var(--text-lit);
  }
</style>
